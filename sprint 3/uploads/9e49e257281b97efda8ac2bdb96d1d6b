// TextScramble class for month animation written in vanilla JS
class TextScramble {
  constructor(el) {
    this.el = el;
    this.update = this.update.bind(this);
    this.queue = [];
    this.frame = 0;
    this.frameRequest = null;
  }

  setText(newText) {
    const hasDot = newText.endsWith(".");
    const targetLetters = hasDot ? newText.slice(0, 3) : newText;
    const newSuffix = hasDot ? "." : "";

    let oldText = this.el.innerText;
    const oldHadDot = oldText.endsWith(".");
    if (oldHadDot) {
      oldText = oldText.slice(0, 3);
    }

    const length = Math.max(oldText.length, targetLetters.length);
    const promise = new Promise((resolve) => (this.resolve = resolve));
    this.queue = [];
    let delay = 0;
    for (let i = 0; i < length; i++) {
      const from = oldText[i] || "";
      const to = targetLetters[i] || "";
      const start = delay;
      const duration = 7;
      const end = start + duration;
      this.queue.push({ from, to, start, end });
      delay = end + 1;
    }
    this.suffix = oldHadDot && !hasDot ? "." : newSuffix;
    this.finalSuffix = newSuffix;
    cancelAnimationFrame(this.frameRequest);
    this.frame = 0;
    this.update();
    return promise;
  }

  setTextBackward(newText) {
    const hasDot = newText.endsWith(".");
    const targetLetters = hasDot ? newText.slice(0, 3) : newText;
    const newSuffix = hasDot ? "." : "";

    let oldText = this.el.innerText;
    const oldHadDot = oldText.endsWith(".");
    if (oldHadDot) {
      oldText = oldText.slice(0, 3);
    }

    const length = Math.max(oldText.length, targetLetters.length);
    const promise = new Promise((resolve) => (this.resolve = resolve));
    this.queue = [];
    let nonDotPositions = [];
    for (let i = 0; i < length; i++) {
      nonDotPositions.push(i);
    }
    const duration = 7;
    const delays = {};
    for (let j = 0; j < nonDotPositions.length; j++) {
      let pos = nonDotPositions[j];
      let revIndex = nonDotPositions.length - 1 - j;
      delays[pos] = revIndex * (duration + 1);
    }
    for (let i = 0; i < length; i++) {
      const from = oldText[i] || "";
      const to = targetLetters[i] || "";
      const start = delays[i] || 0;
      const end = start + duration;
      this.queue.push({ from, to, start, end });
    }
    if (oldHadDot && !hasDot && oldText === "JUN") {
      this.suffix = "";
    } else {
      this.suffix = oldHadDot && !hasDot ? "." : newSuffix;
    }
    this.finalSuffix = newSuffix;
    cancelAnimationFrame(this.frameRequest);
    this.frame = 0;
    this.update();
    return promise;
  }

  update() {
    let output = "";
    let complete = 0;
    for (let i = 0, n = this.queue.length; i < n; i++) {
      let { from, to, start, end, char } = this.queue[i];
      if (this.frame >= end) {
        complete++;
        output += to;
      } else if (this.frame >= start) {
        if (!char || Math.random() < 0.4) {
          char = this.randomChar();
          this.queue[i].char = char;
        }
        output += `<span class="dud">${char}</span>`;
      } else {
        output += from;
      }
    }
    output += this.suffix || "";
    this.el.innerHTML = output;
    if (complete === this.queue.length) {
      this.el.textContent =
        this.queue.map((q) => q.to).join("") + (this.finalSuffix || "");
      this.resolve();
    } else {
      this.frameRequest = requestAnimationFrame(this.update);
      this.frame++;
    }
  }

  randomChar() {
    const allowed = "JANFEBMARAPRMAYJUNJULAUGSEPOCTNOVDEC";
    return allowed[Math.floor(Math.random() * allowed.length)];
  }
}

